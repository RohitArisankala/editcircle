# ─────────────────────────────────────────────────────────────
# EditCircle — environment variables
# Copy this file to `.env.local` and fill in your values.
# The site runs on built-in demo data until these are set.
# ─────────────────────────────────────────────────────────────

# ── Supabase (database + admin login only — NOT video files) ──
# Found in Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional: restrict the admin dashboard to a single email.
# If unset, any authenticated Supabase user can access /admin.
NEXT_PUBLIC_ADMIN_EMAIL=you@example.com

# ── Cloudinary (stores the actual video files — free tier) ──
# Dashboard → Settings → your Cloud name (public, safe to expose).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=YOUR-CLOUD-NAME
# Dashboard → Settings → API Keys. These are SERVER-ONLY — never add
# NEXT_PUBLIC_ to them, or the secret would leak to every visitor.
CLOUDINARY_API_KEY=YOUR-API-KEY
CLOUDINARY_API_SECRET=YOUR-API-SECRET
