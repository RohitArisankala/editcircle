# ─────────────────────────────────────────────────────────────
# EditCircle — environment variables
# Copy this file to `.env.local` and fill in your values.
# The site runs on built-in demo data until these are set.
# ─────────────────────────────────────────────────────────────

# ── Supabase (database + admin login only — NOT video files) ──
# Found in Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional: restrict the admin dashboard to a single email.
# If unset, any authenticated Supabase user can access /admin.
NEXT_PUBLIC_ADMIN_EMAIL=you@example.com

# ── Cloudinary (stores the actual video files — free tier) ──
# Dashboard → Settings → your Cloud name.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=YOUR-CLOUD-NAME
# Settings → Upload → Upload presets → add an UNSIGNED preset, paste its name.
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=YOUR-UNSIGNED-PRESET
